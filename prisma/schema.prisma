datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspaces    WorkspaceUser[]
  activityLogs  ActivityLog[]
  notifications Notification[]
  assignedConversations Conversation[] @relation("AssignedTo")
  payments      Payment[]
  leadNotes     LeadNote[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@unique([provider, providerAccountId])
}
 
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime
 
  @@unique([identifier, token])
}

model Workspace {
  id          String    @id @default(cuid())
  name        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  users       WorkspaceUser[]
  leads       Lead[]
  analytics   WorkspaceAnalytics[]
  conversations Conversation[]
  settings    WorkspaceSettings?
  followUpRules FollowUpRule[]
  
  // Monetization & Usage
  plan          String    @default("FREE") // FREE, PRO, ENTERPRISE
  messageCount  Int       @default(0)
  aiCallCount   Int       @default(0)
  leadCount     Int       @default(0)
  aiInsights    String?   // Cached AI insights
}

model WorkspaceUser {
  id          String    @id @default(cuid())
  role        String    @default("AGENT")
  status      String    @default("ACTIVE")
  userId      String
  workspaceId String
  user        User      @relation(fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  @@unique([userId, workspaceId])
}

model Lead {
  id            String    @id @default(cuid())
  name          String
  email         String?
  phone         String?
  company       String?
  status        String    @default("NEW")
  source        String    @default("MANUAL")
  value         Float     @default(0)
  leadScore     Int       @default(0)
  summary       String?
  nextAction    String?
  followUpDate  DateTime?
  lastContactedAt DateTime?
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  leadNotes     LeadNote[]
  followUps     FollowUp[]
  conversations Conversation[]

  // Lead Intelligence and Automation fields
  intent                 String?   // HOT, WARM, COLD, LOST
  confidenceScore        Float?
  conversionProbability  Float?
  aiSummary              String?
  suggestedActions       String?   // JSON array of actions
  automationRun          Boolean   @default(false)
}

model LeadNote {
  id        String    @id @default(cuid())
  content   String
  leadId    String
  userId    String?
  lead      Lead      @relation(fields: [leadId], references: [id])
  user      User?     @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())
}

model FollowUp {
  id          String    @id @default(cuid())
  dueDate     DateTime
  status      String    @default("PENDING")
  completedAt DateTime?
  leadId      String
  userId      String
  lead        Lead      @relation(fields: [leadId], references: [id])
  createdAt DateTime  @default(now())
}

model FollowUpRule {
  id          String   @id @default(cuid())
  name        String
  triggerDays Int
  condition   String?
  actionType  String   @default("NOTIFICATION")
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ActivityLog {
  id          String   @id @default(cuid())
  workspaceId String
  leadId      String?
  userId      String
  actionType  String
  description String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model WorkspaceAnalytics {
  id                 String   @id @default(cuid())
  workspaceId        String
  date               DateTime
  newLeads           Int      @default(0)
  leadsWon           Int      @default(0)
  followUpsSent      Int      @default(0)
  followupsCompleted Int      @default(0)
  conversionRate     Float    @default(0)
  workspace          Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, date])
}

model Conversation {
  id                    String   @id @default(cuid())
  workspaceId           String
  leadId                String?
  title                 String?
  description           String?
  status                String   @default("OPEN")
  assignedToUserId      String?
  lastMessageAt         DateTime @default(now())
  messageCount          Int      @default(0)
  
  // WhatsApp Integration
  whatsappPhoneId       String?           // WhatsApp Phone ID
  whatsappConversationId String?          // WhatsApp Conversation ID
  whatsappStatus        String?           // WhatsApp sync status
  messageSource         String   @default("MANUAL") // MANUAL, WHATSAPP, API
  
  // Auto-reply settings
  autoReplyEnabled      Boolean  @default(false)
  autoReplyTemplate     String?
  
  // Sales Engine Fields
  intent                String?   // HOT, WARM, COLD, DEAD
  lastFollowUpAt        DateTime?
  conversionStatus      String    @default("PENDING") // PENDING, CONVERTED, LOST
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  workspace  Workspace @relation(fields: [workspaceId], references: [id])
  lead       Lead?     @relation(fields: [leadId], references: [id])
  assignedTo User?     @relation("AssignedTo", fields: [assignedToUserId], references: [id])
  messages   ConversationMessage[]
}

model ConversationMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderType     String   @default("USER") // USER, SYSTEM, AI
  content        String
  messageSource  String   @default("MANUAL") // MANUAL, WHATSAPP, API
  whatsappMessageId String?  // WhatsApp Message ID for tracking
  status         String   @default("SENT") // RECEIVED, SENT, SUGGESTED, FAILED
  
  // Intent detection per message if needed
  detectedIntent String? 
  reasoning      String? 
  
  createdAt      DateTime @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([whatsappMessageId])
}

model WorkspaceSettings {
  id                    String   @id @default(cuid())
  workspaceId           String   @unique
  
  // WhatsApp Configuration
  whatsappBusinessPhoneId String?
  whatsappBusinessAccountId String?
  whatsappAccessToken   String?
  whatsappWebhookToken  String?
  whatsappPhoneNumber   String?
  
  // Auto-reply Configuration
  autoReplyEnabled      Boolean  @default(false)
  defaultAutoReplyText  String   @default("Thanks for your message. We'll get back to you soon!")
  
  // Personalization & Sales Strategy
  businessName          String?
  targetAudience        String?
  businessType          String?   // e.g., Real Estate, SaaS, Agency
  businessTone          String    @default("PROFESSIONAL") // CASUAL, PROFESSIONAL, FRIENDLY, AGGRESSIVE
  businessDescription   String?   // Detailed description of the business
  businessAnalysis      String?   // Structured JSON from AI analysis
  tonePreference        String?   // Specific tone instructions
  pricingInfo           String?   // Details about pricing/plans
  servicesInfo          String?   // Details about services/products
  conversionGoal        String    @default("BOOK_CALL") // BOOK_CALL, SIGNUP, PURCHASE, INFO
  
  // Integration Settings
  integrationsEnabled   String   @default("") // JSON array of enabled integrations
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String   @id @default(cuid())
  userId          String
  amount          Float
  status          String   @default("PENDING") // PENDING, SUCCESS, FAILED
  provider        String   // RAZORPAY, PAYPAL
  transactionId   String?  @unique
  workspaceId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Notification {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  type        String
  title       String
  message     String
  actionUrl   String?
  read        Boolean  @default(false)
  readAt      DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}
